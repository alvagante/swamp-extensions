{
  "name": "swamp",
  "description": "Swamp automation agent with audit tracking",
  "tools": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "thinking",
    "todo"
  ],
  "resources": [
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/**/SKILL.md"
  ],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "swamp .*"
      ]
    }
  },
  "hooks": {
    "postToolUse": [
      {
        "command": "\"/Users/al/.local/bin/swamp\" audit record --from-hook --tool kiro"
      }
    ]
  }
}
